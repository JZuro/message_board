<!DOCTYPE html>
<html>
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Users</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <h1>Users</h1>
    <div id="usersContainer">
      <ul>
        <% users.forEach((user) => { %>
              <li class="name"><%= user.username %></li>
        <% }); %>
      </ul>
    </div>
  </body>
</html>
